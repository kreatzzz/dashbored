{
  "name": "dashbored",
  "version": "0.1.0",
  "description": "A self-hosted service operations dashboard.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "dev:portless": "portless run --name dashbored next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "bun run src/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "bun run prisma/seed.ts",
    "docker:local": "bash scripts/docker-local.sh up",
    "docker:local:down": "bash scripts/docker-local.sh down",
    "docker:local:logs": "bash scripts/docker-local.sh logs",
    "docker:local:status": "bash scripts/docker-local.sh status"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.23",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "^16.2.10",
    "portless": "^0.15.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
